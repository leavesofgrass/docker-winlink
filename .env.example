# Copy this file to .env and edit. Compose reads .env automatically.
#   Windows: Copy-Item .env.example .env      macOS/Linux: cp .env.example .env

# Login name inside the container.
# NOTE: it's HAM_USER, not USERNAME — on Windows USERNAME collides with a
# built-in OS variable and would override this.
HAM_USER=ham

# Account password (also used for SSH and sudo). CHANGE THIS.
USER_PASSWORD=changeme

# Desktop login password (typed in the browser / VNC client). CHANGE THIS.
VNC_PASSWORD=changeme

# Desktop resolution.
VNC_GEOMETRY=1280x800

# Host ports — change any that are already in use on your machine.
VNC_PORT=5900
NOVNC_PORT=6080
SSH_PORT=2424

# Optional: log in over SSH with a key instead of a password. Paste the
# one-line contents of your public key file, e.g.:
#   SSH_PUBKEY=ssh-ed25519 AAAAC3Nza... you@host
SSH_PUBKEY=

# Where audio goes. The default fits Docker Desktop with a PulseAudio server on
# the host. If nothing is listening there the apps just run silently (fine for
# telnet Winlink / packet). On Linux, point this at your host audio socket —
# see the "Sound" section of README.md.
PULSE_SERVER=tcp:host.docker.internal:4713
